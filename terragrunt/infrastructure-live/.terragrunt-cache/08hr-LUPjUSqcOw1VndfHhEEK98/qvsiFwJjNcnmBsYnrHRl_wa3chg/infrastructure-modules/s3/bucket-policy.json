{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AWSCloudTrailAclCheck20150319-1c441d20-435a-4be8-9121-9ee032b3e1fb",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs",
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": "arn:aws:cloudtrail:us-east-2:547580490325:trail/wazuh-cloudtrail"
        }
      }
    },
    {
      "Sid": "AWSCloudTrailWrite20150319-4472b46d-7e47-4bc7-a636-7e9114e1bd75",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/547580490325/*",
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": "arn:aws:cloudtrail:us-east-2:547580490325:trail/wazuh-cloudtrail",
          "s3:x-amz-acl": "bucket-owner-full-control"
        }
      }
    },
    {
      "Sid": "AWSLogDeliveryWrite1",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/547580490325/*",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "547580490325",
          "s3:x-amz-acl": "bucket-owner-full-control"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:logs:us-east-2:547580490325:*"
        }
      }
    },
    {
      "Sid": "AWSLogDeliveryAclCheck1",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "547580490325"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:logs:us-east-2:547580490325:*"
        }
      }
    },
    {
      "Sid": "Deny non-HTTPS access",
      "Effect": "Deny",
      "Principal": {
        "Service": "guardduty.amazonaws.com"
      },
      "Action": "s3:*",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs/*",
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    },
    {
      "Sid": "Deny incorrect encryption header",
      "Effect": "Deny",
      "Principal": {
        "Service": "guardduty.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs/*",
      "Condition": {
        "StringNotEquals": {
          "s3:x-amz-server-side-encryption-aws-kms-key-id": "arn:aws:kms:us-east-2:547580490325:key/b4e50d4e-4399-438d-9f56-ec0b6343b2a4"
        }
      }
    },
    {
      "Sid": "Deny unencrypted object uploads",
      "Effect": "Deny",
      "Principal": {
        "Service": "guardduty.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs/*",
      "Condition": {
        "StringNotEquals": {
          "s3:x-amz-server-side-encryption": "aws:kms"
        }
      }
    },
    {
      "Sid": "Allow PutObject",
      "Effect": "Allow",
      "Principal": {
        "Service": "guardduty.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs/*",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "547580490325",
          "aws:SourceArn": "arn:aws:guardduty:ap-southeast-1:547580490325:detector/d8c4feef959a3ee3ea409cdffbb6f510"
        }
      }
    },
    {
      "Sid": "Allow GetBucketLocation",
      "Effect": "Allow",
      "Principal": {
        "Service": "guardduty.amazonaws.com"
      },
      "Action": "s3:GetBucketLocation",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "547580490325",
          "aws:SourceArn": "arn:aws:guardduty:ap-southeast-1:547580490325:detector/d8c4feef959a3ee3ea409cdffbb6f510"
        }
      }
    }
  ]
}