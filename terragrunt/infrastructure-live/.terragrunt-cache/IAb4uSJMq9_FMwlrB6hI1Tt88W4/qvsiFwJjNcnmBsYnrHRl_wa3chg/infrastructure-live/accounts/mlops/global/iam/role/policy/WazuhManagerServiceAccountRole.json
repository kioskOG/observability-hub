{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WazuhS3Read",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::management-wazuh-aws-logs",
        "arn:aws:s3:::management-wazuh-aws-logs/*"
      ]
    },
    {
      "Sid": "WazuhKmsDecrypt",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt"
      ],
      "Resource": "*"
    },
    {
      "Sid": "WazuhSQSConsume",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes",
        "sqs:GetQueueUrl"
      ],
      "Resource": "arn:aws:sqs:us-east-2:547580490325:wazuh-aws-logs-notify"
    }
  ]
}