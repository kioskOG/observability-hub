{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCloudTrailACLCheck",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs"
    },
    {
      "Sid": "AllowCloudTrailWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": [
        "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/000000000001/*",
        "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/000000000002/*",
        "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/000000000003/*",
        "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/000000000004/*"
      ],
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control",
          "aws:SourceAccount": [
            "000000000001",
            "000000000002",
            "000000000003",
            "000000000004"
          ]
        }
      }
    },
    {
      "Sid": "AllowConfigACLCheck",
      "Effect": "Allow",
      "Principal": {
        "Service": "config.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs"
    },
    {
      "Sid": "AllowConfigWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "config.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": [
        "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/000000000001/Config/*",
        "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/000000000002/Config/*",
        "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/000000000003/Config/*",
        "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/000000000004/Config/*"
      ],
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control"
        }
      }
    },
    {
      "Sid": "AllowGuardDutyWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "guardduty.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/GuardDuty/*",
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control"
        }
      }
    },
    {
      "Sid": "AllowGuardDutyACLCheck",
      "Effect": "Allow",
      "Principal": {
        "Service": "guardduty.amazonaws.com"
      },
      "Action": [
        "s3:GetBucketLocation",
        "s3:GetBucketAcl"
      ],
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs"
    },
    {
      "Sid": "AllowVPCFlowLogsWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs/AWSLogs/*/VPCFlowLogs/*",
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control",
          "aws:SourceAccount": [
            "000000000001",
            "000000000002",
            "000000000003",
            "000000000004"
          ]
        }
      }
    },
    {
      "Sid": "AllowVPCFlowLogsACLCheck",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": [
        "s3:GetBucketAcl",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::management-wazuh-aws-logs",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": [
            "000000000001",
            "000000000002",
            "000000000003",
            "000000000004"
          ]
        }
      }
    },
    {
      "Sid": "DenyInsecureTransport",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::management-wazuh-aws-logs",
        "arn:aws:s3:::management-wazuh-aws-logs/*"
      ],
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    }
  ]
}
