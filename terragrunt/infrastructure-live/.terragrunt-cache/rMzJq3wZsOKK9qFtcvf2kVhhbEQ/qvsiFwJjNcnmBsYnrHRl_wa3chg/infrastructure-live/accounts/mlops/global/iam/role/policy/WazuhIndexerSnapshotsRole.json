{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WazuhSnapshotS3ReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:ListBucketMultipartUploads",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": [
        "arn:aws:s3:::management-wazuh-aws-logs-snapshots",
        "arn:aws:s3:::management-wazuh-aws-logs-snapshots/*"
      ]
    },
    {
      "Sid": "WazuhSnapshotKms",
      "Effect": "Allow",
      "Action": [
        "kms:Encrypt",
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "*"
    }
  ]
}