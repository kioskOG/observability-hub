{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MimirStorage",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:PutObject", "s3:GetObject", "s3:DeleteObject"],
      "Resource": [
        "arn:aws:s3:::millenniumfalcon-mimir-chunks",
        "arn:aws:s3:::millenniumfalcon-mimir-chunks/*",
        "arn:aws:s3:::millenniumfalcon-mimir-ruler",
        "arn:aws:s3:::millenniumfalcon-mimir-ruler/*"
      ]
    }
  ]
}
